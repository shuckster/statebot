{
  "compilerOptions": {
    "allowJs": true,
    "skipLibCheck": true,
    "outDir": "./docs"
  },
  "typedocOptions": {
    "entryPoints": [
      "./index.d.ts",
      "./assert/index.d.ts",
      "./hooks/react/index.d.ts",
      "./hooks/mithril/index.d.ts"
    ],
    "out": "docs",
    "highlightLanguages": [
      "javascript",
      "js",
      "jsx",
      "typescript",
      "ts",
      "tsx",
      "json",
      "bash",
      "shell",
      "mermaid"
    ]
  }
}
